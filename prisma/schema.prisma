generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Fakultas {
  id           Int     @id @default(autoincrement())
  namaFakultas String  @unique @map("nama_fakultas")
  prodis       Prodi[]

  @@map("fakultas")
}

model Prodi {
  id         Int         @id @default(autoincrement())
  namaProdi  String      @unique @map("nama_prodi")
  fakultasId Int         @map("fakultas_id")
  dosens     Dosen[]
  mahasiswas Mahasiswa[]
  peminatans Peminatan[]
  fakultas   Fakultas    @relation(fields: [fakultasId], references: [id])
  ruangans   Ruangan[]

  @@map("prodi")
}

model Peminatan {
  id            Int         @id @default(autoincrement())
  namaPeminatan String      @unique @map("nama_peminatan")
  prodiId       Int         @map("prodi_id")
  mahasiswas    Mahasiswa[]
  prodi         Prodi       @relation(fields: [prodiId], references: [id])

  @@map("peminatan")
}

model Ruangan {
  id          Int     @id @default(autoincrement())
  namaRuangan String  @map("nama_ruangan")
  deskripsi   String?
  prodiId     Int     @map("prodi_id")
  prodi       Prodi   @relation(fields: [prodiId], references: [id])
  ujians      Ujian[]

  @@map("ruangan")
}

model Keputusan {
  id            Int         @id @default(autoincrement())
  kode          String      @unique
  namaKeputusan String      @map("nama_keputusan")
  aktif         Boolean     @default(true)
  jenisUjianId  Int?        @map("jenis_ujian_id")
  jenisUjian    JenisUjian? @relation(fields: [jenisUjianId], references: [id])
  ujians        Ujian[]

  @@map("keputusan")
}

model Role {
  id    Int    @id @default(autoincrement())
  name  String @unique
  users User[]

  @@map("role")
}

model User {
  id        Int        @id @default(autoincrement())
  username  String     @unique
  nama      String
  email     String     @unique
  password  String
  roleId    Int        @map("role_id")
  status    StatusAkun @default(aktif)
  dosen     Dosen?
  mahasiswa Mahasiswa?
  role      Role       @relation(fields: [roleId], references: [id])

  @@map("user")
}

model Dosen {
  id                 Int            @id
  nidn               String?        @unique
  nip                String?        @unique
  noHp               String?        @map("no_hp")
  alamat             String?
  tempatTanggalLahir String?        @map("tempat_tanggal_lahir")
  pangkat            String?
  golongan           String?
  jabatan            String?
  prodiId            Int            @map("prodi_id")
  foto               String?
  urlTtd             String?        @map("url_ttd")
  email              String?        @unique
  status             StatusDosen    @default(aktif)
  user               User           @relation(fields: [id], references: [id])
  prodi              Prodi          @relation(fields: [prodiId], references: [id])
  mahasiswaDosenPa   Mahasiswa[]    @relation("DosenPaRelation")
  mahasiswaPemb1     Mahasiswa[]    @relation("Pembimbing1Relation")
  mahasiswaPemb2     Mahasiswa[]    @relation("Pembimbing2Relation")
  pengujiUjians      PengujiUjian[]
  penilaians         Penilaian[]

  @@map("dosen")
}

model Mahasiswa {
  id                            Int                            @id
  nim                           String                         @unique
  noHp                          String?                        @map("no_hp")
  alamat                        String?
  prodiId                       Int                            @map("prodi_id")
  peminatanId                   Int?                           @map("peminatan_id")
  semester                      Int                            @default(1)
  ipk                           Decimal                        @default(0.00)
  dosenPa                       Int?                           @map("dosen_pa")
  pembimbing1                   Int?                           @map("pembimbing_1")
  pembimbing2                   Int?                           @map("pembimbing_2")
  angkatan                      String?
  foto                          String?
  urlTtd                        String?                        @map("url_ttd")
  status                        StatusAkun                     @default(aktif)
  dokumens                      DokumenMahasiswa[]
  dosenPaRel                    Dosen?                         @relation("DosenPaRelation", fields: [dosenPa], references: [id])
  user                          User                           @relation(fields: [id], references: [id])
  pembimbing1Rel                Dosen?                         @relation("Pembimbing1Relation", fields: [pembimbing1], references: [id])
  pembimbing2Rel                Dosen?                         @relation("Pembimbing2Relation", fields: [pembimbing2], references: [id])
  peminatan                     Peminatan?                     @relation(fields: [peminatanId], references: [id])
  prodi                         Prodi                          @relation(fields: [prodiId], references: [id])
  pendaftaranUjians             PendaftaranUjian[]
  pengajuanRancanganPenelitians PengajuanRancanganPenelitian[]
  perbaikanJuduls               PerbaikanJudul[]
  rancanganPenelitians          RancanganPenelitian[]

  @@map("mahasiswa")
}

model DokumenMahasiswa {
  id          Int          @id @default(autoincrement())
  mahasiswaId Int          @map("mahasiswa_id")
  jenis       JenisDokumen
  fileUrl     String       @map("file_url")
  uploadedAt  DateTime     @default(now()) @map("uploaded_at")
  file_path   String?
  mahasiswa   Mahasiswa    @relation(fields: [mahasiswaId], references: [id])

  @@unique([mahasiswaId, jenis])
  @@map("dokumen_mahasiswa")
}

model RancanganPenelitian {
  id                            Int                            @id @default(autoincrement())
  mahasiswaId                   Int                            @map("mahasiswa_id")
  judulPenelitian               String                         @map("judul_penelitian")
  masalahDanPenyebab            String?                        @map("masalah_dan_penyebab")
  alternatifSolusi              String?                        @map("alternatif_solusi")
  metodePenelitian              String?                        @map("metode_penelitian")
  hasilYangDiharapkan           String?                        @map("hasil_yang_diharapkan")
  kebutuhanData                 String?                        @map("kebutuhan_data")
  jurnalReferensi               String?                        @map("jurnal_referensi")
  pendaftaranUjians             PendaftaranUjian[]
  pengajuanRancanganPenelitians PengajuanRancanganPenelitian[]
  mahasiswa                     Mahasiswa                      @relation(fields: [mahasiswaId], references: [id])

  @@map("rancangan_penelitian")
}

model PengajuanRancanganPenelitian {
  id                    Int                 @id @default(autoincrement())
  rancanganPenelitianId Int                 @map("rancangan_penelitian_id")
  mahasiswaId           Int                 @map("mahasiswa_id")
  tanggalPengajuan      DateTime            @default(now()) @map("tanggal_pengajuan")
  statusDosenPa         StatusPengajuan     @default(menunggu) @map("status_dosen_pa")
  catatanDosenPa        String?             @map("catatan_dosen_pa")
  tanggalReviewPa       DateTime?           @map("tanggal_review_pa")
  statusKaprodi         StatusPengajuan     @default(menunggu) @map("status_kaprodi")
  catatanKaprodi        String?             @map("catatan_kaprodi")
  tanggalReviewKaprodi  DateTime?           @map("tanggal_review_kaprodi")
  komenKprData          String?             @map("komen_kpr_data")
  komenKprHasil         String?             @map("komen_kpr_hasil")
  komenKprMasalah       String?             @map("komen_kpr_masalah")
  komenKprMetode        String?             @map("komen_kpr_metode")
  komenKprSolusi        String?             @map("komen_kpr_solusi")
  komenPaData           String?             @map("komen_pa_data")
  komenPaHasil          String?             @map("komen_pa_hasil")
  komenPaMasalah        String?             @map("komen_pa_masalah")
  komenPaMetode         String?             @map("komen_pa_metode")
  komenPaSolusi         String?             @map("komen_pa_solusi")
  mahasiswa             Mahasiswa           @relation(fields: [mahasiswaId], references: [id])
  rancanganPenelitian   RancanganPenelitian @relation(fields: [rancanganPenelitianId], references: [id])

  @@map("pengajuan_rancangan_penelitian")
}

model JenisUjian {
  id                 Int                 @id @default(autoincrement())
  namaJenis          String              @map("nama_jenis")
  deskripsi          String?
  aktif              Boolean             @default(true)
  keputusans         Keputusan[]
  komponenPenilaians KomponenPenilaian[]
  pendaftaranUjians  PendaftaranUjian[]
  syarats            Syarat[]

  @@map("jenis_ujian")
}

model Syarat {
  id               Int               @id @default(autoincrement())
  jenisUjianId     Int               @map("jenis_ujian_id")
  namaSyarat       String            @map("nama_syarat")
  deskripsi        String?
  wajib            Boolean           @default(true)
  pemenuhanSyarats PemenuhanSyarat[]
  jenisUjian       JenisUjian        @relation(fields: [jenisUjianId], references: [id])

  @@map("syarat")
}

model KomponenPenilaian {
  id                  Int                  @id @default(autoincrement())
  jenisUjianId        Int                  @map("jenis_ujian_id")
  indikatorPenilaian  String?              @map("indikator_penilaian")
  kriteria            String
  bobotKomponenPerans BobotKomponenPeran[]
  jenisUjian          JenisUjian           @relation(fields: [jenisUjianId], references: [id])
  penilaians          Penilaian[]

  @@map("komponen_penilaian")
}

model BobotKomponenPeran {
  id                  Int               @id @default(autoincrement())
  komponenPenilaianId Int               @map("komponen_penilaian_id")
  peran               PengujiPeran
  bobot               Int
  komponenPenilaian   KomponenPenilaian @relation(fields: [komponenPenilaianId], references: [id])

  @@unique([komponenPenilaianId, peran])
  @@map("bobot_komponen_peran")
}

model PendaftaranUjian {
  id                    Int                 @id @default(autoincrement())
  mahasiswaId           Int                 @map("mahasiswa_id")
  jenisUjianId          Int                 @map("jenis_ujian_id")
  tanggalDisetujui      DateTime?           @map("tanggal_disetujui")
  keterangan            String?
  rancanganPenelitianId Int                 @map("rancangan_penelitian_id")
  tanggalPendaftaran    DateTime            @default(now()) @map("tanggal_pendaftaran")
  status                StatusPendaftaran   @default(menunggu)
  pemenuhanSyarats      PemenuhanSyarat[]
  jenisUjian            JenisUjian          @relation(fields: [jenisUjianId], references: [id])
  mahasiswa             Mahasiswa           @relation(fields: [mahasiswaId], references: [id])
  rancanganPenelitian   RancanganPenelitian @relation(fields: [rancanganPenelitianId], references: [id])
  ujian                 Ujian?

  @@map("pendaftaran_ujian")
}

model PemenuhanSyarat {
  id                 Int              @id @default(autoincrement())
  pendaftaranUjianId Int              @map("pendaftaran_ujian_id")
  syaratId           Int              @map("syarat_id")
  keterangan         String?
  fileBukti          String?          @map("file_bukti")
  terpenuhi          Boolean          @default(false)
  pendaftaranUjian   PendaftaranUjian @relation(fields: [pendaftaranUjianId], references: [id])
  syarat             Syarat           @relation(fields: [syaratId], references: [id])

  @@unique([pendaftaranUjianId, syaratId])
  @@map("pemenuhan_syarat")
}

model Ujian {
  id                 Int              @id @default(autoincrement())
  pendaftaranUjianId Int              @unique @map("pendaftaran_ujian_id")
  jadwalUjian        DateTime?        @map("jadwal_ujian")
  waktuMulai         DateTime?        @map("waktu_mulai")
  waktuSelesai       DateTime?        @map("waktu_selesai")
  ruanganId          Int?             @map("ruangan_id")
  nilaiAkhir         Decimal?         @map("nilai_akhir")
  keputusanId        Int?             @map("keputusan_id")
  catatanRevisi      String?          @map("catatan_revisi")
  nilaiHuruf         String?          @map("nilai_huruf")
  status             StatusUjian      @default(belum_dijadwalkan)
  hariUjian          HariUjian?       @map("hari_ujian")
  hasil              HasilUjian?
  finalisasiOleh     Int?             @map("finalisasi_oleh")
  nilaiDifinalisasi  Boolean          @default(false) @map("nilai_difinalisasi")
  tanggalFinalisasi  DateTime?        @map("tanggal_finalisasi")
  pengujiUjians      PengujiUjian[]
  penilaians         Penilaian[]
  keputusan          Keputusan?       @relation(fields: [keputusanId], references: [id])
  pendaftaranUjian   PendaftaranUjian @relation(fields: [pendaftaranUjianId], references: [id])
  ruangan            Ruangan?         @relation(fields: [ruanganId], references: [id])

  @@map("ujian")
}

model PengujiUjian {
  id           Int          @id @default(autoincrement())
  ujianId      Int          @map("ujian_id")
  dosenId      Int          @map("dosen_id")
  peran        PengujiPeran
  hadir        Boolean      @default(false)
  tanggalAbsen DateTime?    @map("tanggal_absen")
  dosen        Dosen        @relation(fields: [dosenId], references: [id])
  ujian        Ujian        @relation(fields: [ujianId], references: [id])

  @@unique([ujianId, dosenId])
  @@map("penguji_ujian")
}

model Penilaian {
  ujianId             Int               @map("ujian_id")
  dosenId             Int               @map("dosen_id")
  komponenPenilaianId Int               @map("komponen_penilaian_id")
  nilai               Decimal?
  komentar            String?
  submittedAt         DateTime?         @map("submitted_at")
  sudahSubmit         Boolean           @default(false) @map("sudah_submit")
  dosen               Dosen             @relation(fields: [dosenId], references: [id])
  komponenPenilaian   KomponenPenilaian @relation(fields: [komponenPenilaianId], references: [id])
  ujian               Ujian             @relation(fields: [ujianId], references: [id])

  @@id([ujianId, dosenId, komponenPenilaianId])
  @@map("penilaian")
}

model PerbaikanJudul {
  id               Int             @id @default(autoincrement())
  mahasiswaId      Int             @map("mahasiswa_id")
  judulLama        String          @map("judul_lama")
  judulBaru        String          @map("judul_baru")
  fileSurat        String          @map("file_surat")
  status           StatusPengajuan @default(menunggu)
  catatanSekprodi  String?         @map("catatan_sekprodi")
  tanggalPengajuan DateTime        @default(now()) @map("tanggal_pengajuan")
  tanggalReview    DateTime?       @map("tanggal_review")
  mahasiswa        Mahasiswa       @relation(fields: [mahasiswaId], references: [id])

  @@map("perbaikan_judul")
}

enum JenisDokumen {
  KTM
  TRANSKRIP_NILAI
  SERTIFIKAT_BTA
  SERTIFIKAT_KKN
  SERTIFIKAT_TOEFL
}

enum StatusAkun {
  aktif
  tidak_aktif
}

enum StatusDosen {
  aktif
  tidak_aktif
}

enum StatusPengajuan {
  menunggu
  diterima
  ditolak
}

enum StatusPendaftaran {
  menunggu
  diterima
  ditolak
  revisi
}

enum StatusUjian {
  belum_dijadwalkan
  dijadwalkan
  selesai
}

enum HasilUjian {
  lulus
  tidak_lulus
}

enum PengujiPeran {
  ketua_penguji
  sekretaris_penguji
  penguji_1
  penguji_2
}

enum HariUjian {
  Senin
  Selasa
  Rabu
  Kamis
  Jumat
  Sabtu
  Minggu
}
